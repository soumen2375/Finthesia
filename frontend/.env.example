VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# AI PDF Parser — pick ONE mode:
# LOCAL (Ollama) — default, no config needed if Ollama is running
VITE_OLLAMA_MODEL=qwen2.5:7b

# PRODUCTION (Together.ai) — uncomment and fill:
# VITE_LLM_API_URL=https://api.together.xyz/v1
# VITE_LLM_API_KEY=your_together_api_key
# VITE_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct-Turbo

# PRODUCTION (Groq) — uncomment and fill:
# VITE_LLM_API_URL=https://api.groq.com/openai/v1
# VITE_LLM_API_KEY=your_groq_api_key
# VITE_LLM_MODEL=qwen-2.5-7b
